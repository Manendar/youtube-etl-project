# Sensitive files - never copy into Docker image
.env
.env.*
kaggle.json
.kaggle/

# Git
.git/
.gitignore

# Docker
docker-compose.yml
docker-compose*.yml

# Jenkins
jenkins/

# Python cache
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Docs (not needed inside container)
README.md
LICENSE
*.md
