pipeline {
    agent any

    environment {
        COMPOSE_FILE = 'docker-compose.yml'
        NOTIFICATION_EMAIL = credentials('notification-email')
        KAGGLE_USERNAME = credentials('kaggle-username')
        KAGGLE_KEY = credentials('kaggle-key')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Checkout =========='
                checkout scm
                sh 'git log --oneline -1'
            }
        }

        stage('Validate') {
            steps {
                echo '========== Validate =========='
                sh '''
                    echo "Checking required files..."
                    test -f docker-compose.yml   || { echo "Missing docker-compose.yml"; exit 1; }
                    test -f Dockerfile           || { echo "Missing Dockerfile"; exit 1; }
                    test -f requirements.txt     || { echo "Missing requirements.txt"; exit 1; }
                    test -f entrypoint.sh        || { echo "Missing entrypoint.sh"; exit 1; }
                    test -d dags                 || { echo "Missing dags/"; exit 1; }
                    test -d scripts              || { echo "Missing scripts/"; exit 1; }
                    test -d spark_jobs           || { echo "Missing spark_jobs/"; exit 1; }
                    test -d envs                 || { echo "Missing envs/"; exit 1; }
                    echo "All required files present"
                '''
            }
        }

        stage('Lint') {
            steps {
                echo '========== Lint =========='
                sh '''
                    echo "Checking Python syntax..."
                    find . -name "*.py" -not -path "./.git/*" | while read file; do
                        python3 -m py_compile "$file" && echo "OK: $file"
                    done
                    echo "Python syntax check passed"
                '''
            }
        }

        stage('Build') {
            steps {
                echo '========== Build =========='
                sh '''
                    echo "Building Docker images..."
                    docker-compose -f ${COMPOSE_FILE} build --no-cache
                    echo "Docker images built successfully"
                '''
            }
        }

        stage('Start Services') {
            steps {
                echo '========== Start Services =========='
                sh '''
                    echo "Creating .env file..."
                    echo "KAGGLE_USERNAME=${KAGGLE_USERNAME}" > .env
                    echo "KAGGLE_KEY=${KAGGLE_KEY}" >> .env
                    echo "ENVIRONMENT=dev" >> .env
                    
                    echo "Starting all services..."
                    docker-compose -f ${COMPOSE_FILE} down -v 2>/dev/null || true
                    docker-compose -f ${COMPOSE_FILE} up -d
                    echo "Waiting 90 seconds for services to stabilize..."
                    sleep 90
                    echo "Services started"
                '''
            }
        }

        stage('Health Check') {
            steps {
                echo '========== Health Check =========='
                sh '''
                    echo "Checking service health..."
                    docker-compose -f ${COMPOSE_FILE} ps

                    for service in hadoop_namenode hadoop_datanode pyspark-app airflow_webserver airflow_scheduler; do
                        if docker ps | grep -q "$service"; then
                            echo "OK: $service is running"
                        else
                            echo "FAILED: $service is NOT running"
                            exit 1
                        fi
                    done

                    echo "All services healthy"
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                echo '========== Integration Tests =========='
                sh '''
                    echo "Testing HDFS connectivity..."
                    docker exec pyspark-app python3 -c "
from hdfs import InsecureClient
client = InsecureClient('http://namenode:9870', user='hadoop', timeout=30)
client.status('/', strict=False)
print('HDFS connection successful')
"
                    echo "Testing Python dependencies..."
                    docker exec pyspark-app python3 -c "
import pandas, pyspark, kaggle
from hdfs import InsecureClient
print('All Python packages available')
"
                    echo "Integration tests passed"
                '''
            }
        }

        stage('DAG Validation') {
            steps {
                echo '========== DAG Validation =========='
                sh '''
                    echo "Validating Airflow DAGs..."
                    docker exec airflow_webserver airflow dags list
                    echo "DAG validation passed"
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo '========== Deploy =========='
                sh '''
                    echo "Deployment successful!"
                    echo "=================================="
                    echo "Airflow:  http://localhost:8082"
                    echo "HDFS:     http://localhost:9870"
                    echo "Metabase: http://localhost:3000"
                    echo "Jenkins:  http://localhost:8080"
                    echo "=================================="
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
            mail(
                to: "${env.NOTIFICATION_EMAIL}",
                subject: "Pipeline Succeeded: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Pipeline ${env.JOB_NAME} completed successfully!

Build: #${env.BUILD_NUMBER}
Duration: ${currentBuild.durationString}
URL: ${env.BUILD_URL}

All services are running:
- Airflow:  http://localhost:8082
- HDFS:     http://localhost:9870
- Metabase: http://localhost:3000
                """
            )
        }
        failure {
            echo 'Pipeline failed!'
            mail(
                to: "${env.NOTIFICATION_EMAIL}",
                subject: "Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Pipeline ${env.JOB_NAME} FAILED!

Build: #${env.BUILD_NUMBER}
Duration: ${currentBuild.durationString}
URL: ${env.BUILD_URL}

Please check the logs at:
${env.BUILD_URL}console

Fix the issue and push again.
                """
            )
        }
        always {
            echo 'Pipeline execution completed'
        }
    }
}
