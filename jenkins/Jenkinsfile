pipeline {
    agent any

    environment {
        COMPOSE_FILE = 'docker-compose.yml'
        NOTIFICATION_EMAIL = credentials('notification-email')
        KAGGLE_USERNAME = credentials('kaggle-username')
        KAGGLE_KEY = credentials('kaggle-key')
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                echo '========== Checkout =========='
                checkout scm
                sh 'git log --oneline -1'
            }
        }

        stage('Validate') {
            steps {
                echo '========== Validate =========='
                sh '''
                    echo "Checking required files..."
                    test -f docker-compose.yml   || { echo "Missing docker-compose.yml"; exit 1; }
                    test -f Dockerfile           || { echo "Missing Dockerfile"; exit 1; }
                    test -f requirements.txt     || { echo "Missing requirements.txt"; exit 1; }
                    test -f entrypoint.sh        || { echo "Missing entrypoint.sh"; exit 1; }
                    test -d dags                 || { echo "Missing dags/"; exit 1; }
                    test -d scripts              || { echo "Missing scripts/"; exit 1; }
                    test -d spark_jobs           || { echo "Missing spark_jobs/"; exit 1; }
                    test -d envs                 || { echo "Missing envs/"; exit 1; }
                    echo "All required files present"
                '''
            }
        }

        stage('Lint') {
            steps {
                echo '========== Lint =========='
                sh '''
                    echo "Checking Python syntax..."
                    find . -name "*.py" -not -path "./.git/*" | while read file; do
                        python3 -m py_compile "$file" && echo "OK: $file"
                    done
                    echo "Python syntax check passed"
                '''
            }
        }

        stage('Build Image') {
            steps {
                echo '========== Build Image =========='
                sh '''
                    echo "Creating .env file for build..."
                    echo "KAGGLE_USERNAME=${KAGGLE_USERNAME}" > .env
                    echo "KAGGLE_KEY=${KAGGLE_KEY}" >> .env
                    echo "ENVIRONMENT=dev" >> .env

                    echo "Building PySpark Docker image..."
                    docker build -t youtube-etl-pyspark .
                    echo "Docker image built successfully"
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                echo '========== Integration Tests =========='
                sh '''
                    echo "Testing that all services are running..."

                    for service in hadoop_namenode hadoop_datanode pyspark-app airflow_webserver airflow_scheduler; do
                        if docker ps | grep -q "$service"; then
                            echo "OK: $service is running"
                        else
                            echo "WARNING: $service is not running (expected if testing code only)"
                        fi
                    done

                    echo "Testing HDFS connectivity..."
                    docker exec pyspark-app python3 -c "
from hdfs import InsecureClient
client = InsecureClient('http://namenode:9870', user='hadoop', timeout=30)
client.status('/', strict=False)
print('HDFS connection successful')
" || echo "WARNING: HDFS test skipped (services may not be running)"

                    echo "Integration tests completed"
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo '========== Deploy =========='
                sh '''
                    echo "Pipeline validated successfully!"
                    echo "=================================="
                    echo "Code is validated and ready"
                    echo "Docker image built successfully"
                    echo "=================================="
                    echo "Services (if running):"
                    echo "  Airflow:  http://localhost:8082"
                    echo "  HDFS:     http://localhost:9870"
                    echo "  Metabase: http://localhost:3000"
                    echo "  Jenkins:  http://localhost:8080"
                    echo "=================================="
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
            mail(
                to: "${env.NOTIFICATION_EMAIL}",
                subject: "Pipeline Succeeded: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Pipeline ${env.JOB_NAME} completed successfully!\n\nBuild: #${env.BUILD_NUMBER}\nURL: ${env.BUILD_URL}"
            )
        }
        failure {
            echo 'Pipeline failed!'
            mail(
                to: "${env.NOTIFICATION_EMAIL}",
                subject: "Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Pipeline ${env.JOB_NAME} FAILED!\n\nBuild: #${env.BUILD_NUMBER}\nURL: ${env.BUILD_URL}\n\nPlease check the logs."
            )
        }
        always {
            echo 'Pipeline execution completed'
        }
    }
}
